# ─── Banco de dados Firebird ───────────────────────────────────────────────────
# Host onde o Firebird está rodando (após o túnel SSH, sempre localhost)
DB_HOST=localhost

# Porta padrão do Firebird (não alterar salvo configuração diferente)
DB_PORT=3050

# Caminho do arquivo .gdb/.fdb no servidor Linux
DB_PATH=/u10/c6bank/dados/scci.gdb

# Usuário do Firebird
DB_USER=SYSDBA

# Senha do Firebird
DB_PASSWORD=sua_senha_firebird

# Encoding do banco (WIN1252 para bancos legados brasileiros, ou UTF8)
DB_CHARSET=WIN1252


# ─── Túnel SSH ─────────────────────────────────────────────────────────────────
# IP do servidor da empresa
SSH_HOST=10.3.98.108

# Porta SSH do servidor (padrão é 22, mas pode ser diferente)
SSH_PORT=23

# Seu usuário Linux da empresa
SSH_USER=seu_usuario_linux

# Sua senha Linux da empresa
SSH_PASSWORD=sua_senha_linux


# ─── API FastAPI ────────────────────────────────────────────────────────────────
# Deixar localhost — só muda se subir em servidor
API_HOST=localhost
API_PORT=8000
